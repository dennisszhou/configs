# --- Environment & Editor ---
export VISUAL='vim'
export EDITOR="$VISUAL"

# --- History Settings ---
export HISTFILESIZE=1000000000
export HISTSIZE=1000000
export HISTTIMEFORMAT="%F %T "

# --- Tool Configurations ---
export FZF_TMUX=1
export FZF_DEFAULT_OPTS="--height 40%"

# --- Shared Colors ---
export CLICOLOR=1

# --- Local Overrides ---
[ -f ~/.shrc.local ] && source ~/.shrc.local
