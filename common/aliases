# bash aliases
alias f='find ./ -name '

alias gr='grep -r'
alias gri='grep -ri'
alias iq='igrep query'

alias ggi='git grep -i'
alias gs='git branch -vv && git status'
alias gt='git ls-tree -r --name-only HEAD | tree --fromfile'

alias ta='tmux attach -t'
alias td='tmux detach'
alias tls='tmux ls'

alias reset="clear && printf '\e[3J'"
